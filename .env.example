# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/yeschef

# Sysco catalog path (inside Docker container)
SYSCO_CSV_PATH=/app/data/sysco_catalog.csv

# LLM API key (choose one)
OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Models
DECOMPOSITION_MODEL=openai:gpt-4o-mini
MATCHING_MODEL=openai:gpt-4o-mini

# Optional: Exa API for recipe retrieval (improves decomposition quality)
# EXA_API_KEY=...
